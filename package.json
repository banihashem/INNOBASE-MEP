{
  "name": "mep-light",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "test": "node --import tsx tests/scoring_engine.test.ts",
    "test:prep": "node --import tsx tests/product_prep.test.ts",
    "test:golden": "node --import tsx tests/golden_scenario_somayeh.ts",
    "test:pdf": "node --import tsx tests/pdf_export.test.ts",
    "test:all": "npm run test && npm run test:prep && npm run test:golden",
    "api": "node --import tsx backend/src/api_server.ts",
    "pdf-service": "python backend/pdf_service/app.py"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "lucide-react": "^0.546.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "vite": "^6.2.3",
    "express": "^4.21.2",
    "dotenv": "^17.2.3",
    "motion": "^12.23.24"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "@types/express": "^4.17.21"
  }
}
